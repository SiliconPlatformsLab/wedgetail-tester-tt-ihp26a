*  a custom spiceinit file for IHP-Open-PDK

* export PDK_ROOT and PDK environmental variables first and add it to your .bashrc
* export PDK_ROOT= installation_specific_directory/IHP-Open-PDK
* export PDK=ihp-sg13g2

setcs sourcepath = (  $sourcepath /home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/models /home/matt/.ciel/ihp-sg13g2/libs.ref/sg13g2_stdcell/spice )
setcs sourcepath = (  $sourcepath /home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/models /home/matt/.ciel/ihp-sg13g2/libs.ref/sg13g2_io/spice )
*echo $sourcepath

*option tnom=28
*option list

* KLU solver still do not work correctly for every simulation
option klu

set num_threads=16

*option node
*option opts
*option warn=1
*option maxwarns=10
option savecurrents

set ngbehavior=hsa
*set noinit

* add OSDI
osdi  '/home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/osdi/psp103.osdi'
osdi  '/home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/osdi/psp103_nqs.osdi'
osdi  '/home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/osdi/r3_cmc.osdi'
osdi  '/home/matt/.ciel/ihp-sg13g2/libs.tech/ngspice/osdi/mosvar.osdi'

echo ngspice .spiceinit loaded OK
